# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/healthsync
MONGO_URI_TEST=mongodb://localhost:27017/healthsync_test

# ─── JWT Secrets (minimum 64 random characters each) ─────
ACCESS_TOKEN_SECRET=your_access_token_secret_here_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxxx
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxx

# ─── Frontend URL (for CORS) ─────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── SMTP Email Settings (Optional) ────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HealthSync <no-reply@healthsync.com>"

# ─── Admin Bootstrap (used ONLY by `npm run seed:admin`) ───
# There is no public admin sign-up endpoint by design — admin accounts are
# provisioned by running scripts/seedAdmin.js with these set. Treat these as
# one-time bootstrap values, not the account's real password:
#   1. Set them here (or inline on the command), run `npm run seed:admin`.
#   2. Log in once at /admin/login.
#   3. Change the password immediately and delete these four lines from your
#      local .env. Never commit real values for these.
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_FIRST_NAME=
ADMIN_SEED_LAST_NAME=
ADMIN_SEED_MOBILE=
# ADMIN_SEED_ROLE=admin   # or 'superadmin'; defaults to 'admin'
