# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/healthsync
MONGO_URI_TEST=mongodb://localhost:27017/healthsync_test

# ─── JWT Secrets (minimum 64 random characters each) ─────
ACCESS_TOKEN_SECRET=your_access_token_secret_here_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxxx
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxx

# ─── Frontend URL (for CORS) ─────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── SMTP Email Settings (Optional) ────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HealthSync <no-reply@healthsync.com>"
